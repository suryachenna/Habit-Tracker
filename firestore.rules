rules_version = '2';

// Paste this into: Firebase Console -> Firestore Database -> Rules tab -> Publish
//
// This ensures each signed-in user can ONLY read/write their OWN document
// (keyed by their Firebase uid), so one user can never see another's habits.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
